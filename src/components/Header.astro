---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import ThemeIcon from './ThemeIcon.astro';
import SocialLinks from './SocialLinks.astro';
---

<style>
	header {
		margin: 0;
		padding: 0 1em;
		background-color: var(--background-body); /* Ora la variabile esiste! */
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
		position: sticky;
		top: 0;
		z-index: 1000;
		width: 100%;
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 70px;
		max-width: 960px;
		margin: 0 auto;
	}

	.header-controls {
		display: flex;
		align-items: center;
		gap: 15px;
	}

	.menu-button {
		display: none;
		background: none;
		border: 1.5px solid currentColor; /* Usa il colore del testo corrente */
		border-radius: 6px;
		padding: 5px;
		cursor: pointer;
		color: inherit;
		line-height: 0;
	}

	.internal-links {
		display: flex;
		gap: 20px;
	}

	@media (max-width: 720px) {
		.menu-button {
			display: block !important; /* Forza apparizione */
		}

		.desktop-socials {
			display: none !important;
		}

		.internal-links {
			display: none; 
			flex-direction: column;
			position: absolute;
			top: 100%; /* Sotto l'header */
			left: 0;
			width: 100%;
			background-color: var(--background-body);
			padding: 2em 1em;
			box-shadow: 0 10px 15px rgba(0,0,0,0.1);
			z-index: 999;
		}

		.internal-links.show {
			display: flex !important;
		}
	}
</style>