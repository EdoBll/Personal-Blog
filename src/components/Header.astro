---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import ThemeIcon from './ThemeIcon.astro';
import SocialLinks from './SocialLinks.astro';
---

<header>
	<nav>
		<div class="nav-left">
			<h2><a href={import.meta.env.BASE_URL}>{SITE_TITLE}</a></h2>
		</div>
		
		<div class="internal-links" id="nav-menu">
			<HeaderLink href={`${import.meta.env.BASE_URL}/`}>Home</HeaderLink>
			<HeaderLink href={`${import.meta.env.BASE_URL}/blog`}>Blog</HeaderLink>
			<HeaderLink href={`${import.meta.env.BASE_URL}/about`}>About</HeaderLink>
		</div>

		<div class="header-controls">
			<ThemeIcon />
			<button id="menu-toggle" aria-label="Menu" class="menu-button">
				<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<line x1="3" y1="12" x2="21" y2="12"></line>
					<line x1="3" y1="6" x2="21" y2="6"></line>
					<line x1="3" y1="18" x2="21" y2="18"></line>
				</svg>
			</button>
			<div class="desktop-socials">
				<SocialLinks />
			</div>
		</div>
	</nav>
</header>

<script>
	// Funzione per gestire il menu, compatibile con Astro View Transitions
	function initMenu() {
		const btn = document.getElementById('menu-toggle');
		const menu = document.getElementById('nav-menu');

		if (btn && menu) {
			// Rimuoviamo eventuali listener precedenti per evitare duplicati
			btn.onclick = () => {
				menu.classList.toggle('show');
			};
		}
	}

	// Inizializzazione
	initMenu();
	document.addEventListener('astro:after-swap', initMenu);
</script>

<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: var(--background-body, white);
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
		position: sticky;
		top: 0;
		z-index: 100;
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 70px;
	}

	h2 {
		margin: 0;
		font-size: 1.1em;
		white-space: nowrap;
	}

	h2 a {
		text-decoration: none;
		color: var(--black);
	}

	.internal-links {
		display: flex;
		gap: 20px;
	}

	.header-controls {
		display: flex;
		align-items: center;
		gap: 12px;
	}

	.menu-button {
		display: none; /* Nascosto su desktop */
		background: none;
		border: 1px solid #ccc;
		border-radius: 4px;
		cursor: pointer;
		color: var(--black);
		padding: 6px;
		line-height: 0;
	}

	.desktop-socials {
		display: flex;
		align-items: center;
	}

	/* --- MOBILE OPTIMIZATION --- */
	@media (max-width: 720px) {
		.desktop-socials {
			display: none !important;
		}

		.menu-button {
			display: flex !important;
		}

		/* Nascondiamo i link centrali e li trasformiamo in menu a tendina */
		nav .internal-links {
			display: none; 
			flex-direction: column;
			position: absolute;
			top: 70px;
			left: 0;
			width: 100%;
			background: var(--background-body, white);
			padding: 1.5em;
			box-shadow: 0 10px 15px rgba(0,0,0,0.1);
			gap: 1.5em;
			text-align: center;
			border-top: 1px solid #eee;
		}

		/* Mostra il menu quando ha la classe .show */
		nav .internal-links.show {
			display: flex;
		}
	}
</style>