---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
import ThemeIcon from './ThemeIcon.astro';
---

<header>
	<nav>
		<div class="nav-left">
			<h2><a href={import.meta.env.BASE_URL}>{SITE_TITLE}</a></h2>
		</div>

		<div class="internal-links" id="nav-menu">
			<HeaderLink href={`${import.meta.env.BASE_URL}/`}>Home</HeaderLink>
			<HeaderLink href={`${import.meta.env.BASE_URL}/blog`}>Blog</HeaderLink>
			<HeaderLink href={`${import.meta.env.BASE_URL}/about`}>About</HeaderLink>
		</div>

		<div class="header-controls">
			<div class="social-links-header">
				<a href="https://www.linkedin.com/pub/dir/Edoardo/Belli" target="_blank" aria-label="LinkedIn">
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
				</a>
				<a href="https://github.com/EdoBll" target="_blank" aria-label="GitHub">
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.298 24 12c0-6.627-5.373-12-12-12z"/></svg>
				</a>
			</div>
			
			<ThemeIcon />
			
			<button id="menu-toggle" aria-label="Menu" class="menu-button">
				<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
					<line x1="3" y1="12" x2="21" y2="12"></line>
					<line x1="3" y1="6" x2="21" y2="6"></line>
					<line x1="3" y1="18" x2="21" y2="18"></line>
				</svg>
			</button>
		</div>
	</nav>
</header>

<script>
	const initMenu = () => {
		const btn = document.getElementById('menu-toggle');
		const menu = document.getElementById('nav-menu');
		if (btn && menu) {
			btn.onclick = (e) => {
				e.stopPropagation();
				menu.classList.toggle('show');
			};
			document.onclick = () => menu.classList.remove('show');
		}
	};
	initMenu();
	document.addEventListener('astro:after-swap', initMenu);
</script>

<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: var(--background-body);
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
		position: sticky;
		top: 0;
		z-index: 1000;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 960px;
		margin: 0 auto;
		height: 70px;
	}
	h2 { margin: 0; font-size: 1.2em; }
	h2 a { text-decoration: none; color: inherit; }

	.internal-links {
		display: flex;
		gap: 1.5em;
	}

	.header-controls {
		display: flex;
		align-items: center;
		gap: 1.2em;
	}

	.social-links-header {
		display: flex;
		gap: 1em;
		align-items: center;
	}
	
	.social-links-header a {
		display: flex;
		color: var(--black);
		transition: opacity 0.2s;
	}

	.social-links-header a:hover {
		opacity: 0.7;
	}

	.menu-button {
		display: none;
		background: none;
		border: none;
		cursor: pointer;
		color: inherit;
		padding: 5px;
	}

	@media (max-width: 720px) {
		.social-links-header {
			display: none; /* Nascondi dall'header su mobile, rimangono nel footer */
		}
		
		.menu-button {
			display: block;
		}

		.internal-links {
			display: none;
			flex-direction: column;
			position: absolute;
			top: 70px;
			left: 0;
			width: 100%;
			background: var(--background-body);
			padding: 1em;
			box-shadow: 0 4px 8px rgba(0,0,0,0.1);
		}

		.internal-links.show {
			display: flex;
		}
	}
</style>