---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import ThemeIcon from './ThemeIcon.astro'; //Button per cambio tema (scuro-chiaro) //
import SocialLinks from './SocialLinks.astro';
---

<header>
	<nav>
		<h2><a href={import.meta.env.BASE_URL}>{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href={`${import.meta.env.BASE_URL}/`}>Home</HeaderLink>
			<HeaderLink href={`${import.meta.env.BASE_URL}/blog`}>Blog</HeaderLink>
			<HeaderLink href={`${import.meta.env.BASE_URL}/about`}>About</HeaderLink>
		</div>
		<div class="social-wrapper">
			<ThemeIcon />
			<SocialLinks />
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: var(--background-body, white);
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}

	nav {
		display: grid;
		grid-template-columns: auto 1fr auto; /* Titolo | Spazio/Link | Tema */
		align-items: center;
		height: 100%;
		gap: 1em;
	}

	h2 {
		margin: 0;
		font-size: 1em;
		white-space: nowrap; /* Impedisce al nome di andare a capo */
	}

	h2 a {
		text-decoration: none;
		color: var(--black);
	}

	.internal-links {
		display: flex;
		gap: 15px;
		justify-self: center;
	}

	.social-wrapper {
		display: flex;
		align-items: center;
		gap: 0.8em;
		justify-self: end;
	}

	nav a {
		padding: 1em 0.2em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
		font-size: 0.95em;
	}

	nav a.active {
		border-bottom-color: var(--accent);
	}

	/* --- GESTIONE MOBILE --- */
	@media (max-width: 720px) {
		/* Usiamo :global per nascondere il componente SocialLinks dall'header */
		.social-wrapper :global(.social-links) {
			display: none;
		}

		nav {
			/* Compattiamo la griglia per far stare tutto su una riga */
			grid-template-columns: auto 1fr auto;
			gap: 0.5em;
		}

		h2 {
			font-size: 0.9em;
		}

		.internal-links {
			gap: 8px; /* Stringiamo lo spazio tra Home, Blog e About */
		}

		nav a {
			padding: 0.8em 0.2em;
			font-size: 0.85em; /* Font leggermente più piccolo per mobile */
		}
	}
</style>