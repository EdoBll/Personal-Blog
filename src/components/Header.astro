---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import ThemeIcon from './ThemeIcon.astro';
import SocialLinks from './SocialLinks.astro';
---

<header>
	<nav>
		<h2><a href={import.meta.env.BASE_URL}>{SITE_TITLE}</a></h2>
		
		<div class="internal-links" id="nav-menu">
			<HeaderLink href={`${import.meta.env.BASE_URL}/`}>Home</HeaderLink>
			<HeaderLink href={`${import.meta.env.BASE_URL}/blog`}>Blog</HeaderLink>
			<HeaderLink href={`${import.meta.env.BASE_URL}/about`}>About</HeaderLink>
		</div>

		<div class="header-controls">
			<ThemeIcon />
			<button id="menu-toggle" aria-label="Menu" class="menu-button">
				<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<line x1="3" y1="12" x2="21" y2="12"></line>
					<line x1="3" y1="6" x2="21" y2="6"></line>
					<line x1="3" y1="18" x2="21" y2="18"></line>
				</svg>
			</button>
			<div class="desktop-socials">
				<SocialLinks />
			</div>
		</div>
	</nav>
</header>

<script>
	const btn = document.getElementById('menu-toggle');
	const menu = document.getElementById('nav-menu');

	btn?.addEventListener('click', () => {
		menu?.classList.toggle('show');
	});
</script>

<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: var(--background-body, white);
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
		position: relative;
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 70px;
	}

	h2 {
		margin: 0;
		font-size: 1.1em;
	}

	h2 a {
		text-decoration: none;
		color: var(--black);
	}

	.internal-links {
		display: flex;
		gap: 20px;
	}

	.header-controls {
		display: flex;
		align-items: center;
		gap: 1em;
	}

	.menu-button {
		display: none; /* Nascosto su desktop */
		background: none;
		border: none;
		cursor: pointer;
		color: var(--black);
		padding: 5px;
	}

	/* --- MOBILE LAYOUT --- */
	@media (max-width: 720px) {
		.desktop-socials {
			display: none; /* Nascondiamo i social dall'header su mobile */
		}

		.menu-button {
			display: block; /* Mostriamo l'hamburger */
		}

		.internal-links {
			display: none; /* Nascondiamo il menù classico */
			flex-direction: column;
			position: absolute;
			top: 70px;
			left: 0;
			width: 100%;
			background: var(--background-body, white);
			padding: 1em;
			box-shadow: 0 4px 8px rgba(0,0,0,0.1);
			z-index: 10;
			gap: 10px;
		}

		.internal-links.show {
			display: flex; /* Mostriamo il menù al click */
		}
	}
</style>