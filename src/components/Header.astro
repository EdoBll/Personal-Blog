---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import ThemeIcon from './ThemeIcon.astro';
import SocialLinks from './SocialLinks.astro';
---

<header>
	<nav>
		<div class="nav-left">
			<h2><a href={import.meta.env.BASE_URL}>{SITE_TITLE}</a></h2>
		</div>
		
		<div class="internal-links" id="nav-menu">
			<HeaderLink href={`${import.meta.env.BASE_URL}/`}>Home</HeaderLink>
			<HeaderLink href={`${import.meta.env.BASE_URL}/blog`}>Blog</HeaderLink>
			<HeaderLink href={`${import.meta.env.BASE_URL}/about`}>About</HeaderLink>
		</div>

		<div class="header-controls">
			<ThemeIcon />
			<button id="menu-toggle" aria-label="Menu" class="menu-button">
				<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<line x1="3" y1="12" x2="21" y2="12"></line>
					<line x1="3" y1="6" x2="21" y2="6"></line>
					<line x1="3" y1="18" x2="21" y2="18"></line>
				</svg>
			</button>
			<div class="desktop-socials">
				<SocialLinks />
			</div>
		</div>
	</nav>
</header>

<script>
	// Funzione per gestire il menu, compatibile con Astro View Transitions
	function initMenu() {
		const btn = document.getElementById('menu-toggle');
		const menu = document.getElementById('nav-menu');

		if (btn && menu) {
			// Rimuoviamo eventuali listener precedenti per evitare duplicati
			btn.onclick = () => {
				menu.classList.toggle('show');
			};
		}
	}

	// Inizializzazione
	initMenu();
	document.addEventListener('astro:after-swap', initMenu);
</script>

<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: var(--background-body, white);
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
		position: sticky;
		top: 0;
		z-index: 1000; /* Valore molto alto per stare sopra a tutto */
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 70px;
	}

	.header-controls {
		display: flex;
		align-items: center;
		gap: 12px;
		position: relative;
		z-index: 1010; /* Ancora più alto dell'header */
	}

	.menu-button {
		display: none;
		background: rgba(var(--gray), 10%); /* Leggero sfondo per test */
		border: 1px solid rgba(var(--gray), 20%);
		border-radius: 6px;
		cursor: pointer;
		color: currentColor;
		padding: 8px;
		line-height: 0;
	}

	/* ... resto del tuo CSS per .internal-links ... */

	@media (max-width: 720px) {
		.menu-button {
			display: flex !important; /* Forza la visibilità su mobile */
		}
        
        /* Forza la sparizione dei link orizzontali */
        .internal-links {
            display: none !important;
        }

        .internal-links.show {
            display: flex !important;
            /* ... il resto del tuo stile per il menu a tendina ... */
        }
	}
</style>