---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
import ThemeIcon from './ThemeIcon.astro';
import SocialLinks from './SocialLinks.astro'; // <--- Importiamo il tuo componente perfetto
---

<header>
	<nav>
		<div class="header-controls">
			<div class="social-links-header">
				<SocialLinks /> </div>
			
			<ThemeIcon />
			
			<button id="menu-toggle" aria-label="Menu" class="menu-button">
				<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
					<line x1="3" y1="12" x2="21" y2="12"></line>
					<line x1="3" y1="6" x2="21" y2="6"></line>
					<line x1="3" y1="18" x2="21" y2="18"></line>
				</svg>
			</button>
		</div>

		<div class="nav-left">
			<h2><a href={import.meta.env.BASE_URL}>{SITE_TITLE}</a></h2>
		</div>

		<div class="internal-links" id="nav-menu">
			<HeaderLink href={`${import.meta.env.BASE_URL}/`}>Home</HeaderLink>
			<HeaderLink href={`${import.meta.env.BASE_URL}/blog`}>Blog</HeaderLink>
			<HeaderLink href={`${import.meta.env.BASE_URL}/about`}>About</HeaderLink>
		</div>
	</nav>
</header>

<script>
	const initMenu = () => {
		const btn = document.getElementById('menu-toggle');
		const menu = document.getElementById('nav-menu');
		if (btn && menu) {
			btn.onclick = (e) => {
				e.stopPropagation();
				menu.classList.toggle('show');
			};
			document.onclick = () => menu.classList.remove('show');
		}
	};
	initMenu();
	document.addEventListener('astro:after-swap', initMenu);
</script>

<style>
	header {
		margin: 0;
		padding: 0 2em; /* Padding laterale per non far toccare i bordi */
		background: var(--background-body);
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
		position: sticky;
		top: 0;
		z-index: 1000;
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 100%; /* Rimosso il limite di 960px per spingere tutto ai lati */
		height: 70px;
		margin: 0 auto;
	}

	h2 { margin: 0; font-size: 1.2em; white-space: nowrap; }
	h2 a { text-decoration: none; color: inherit; }

	.internal-links {
		display: flex;
		gap: 1.5em;
		/* Centra i link interni nel mezzo dello spazio disponibile */
		position: absolute;
		left: 50%;
		transform: translateX(-50%);
	}

	.header-controls {
		display: flex;
		align-items: center;
		gap: 1.2em;
	}

	/* CSS per adattare leggermente il componente SocialLinks all'header */
	.social-links-header :global(.social-links) {
		gap: 0.6em; /* Un po' più compatto per l'header */
	}

	.social-links-header :global(.social-links a) {
		width: 30px; /* Leggermente più piccole rispetto al footer per eleganza */
		height: 30px;
	}

	.menu-button {
		display: none;
		background: none;
		border: none;
		cursor: pointer;
		color: inherit;
		padding: 5px;
	}

	@media (max-width: 720px) {
		.social-links-header {
			display: none;
		}
		
		.menu-button {
			display: block;
		}

		.internal-links {
			position: absolute; /* Reset per il menu mobile */
			top: 70px;
			left: 0;
			transform: none;
			width: 100%;
			display: none;
			flex-direction: column;
			background: var(--background-body);
			padding: 1em;
			box-shadow: 0 4px 8px rgba(0,0,0,0.1);
		}

		.internal-links.show {
			display: flex;
		}
	}
</style>