---
interface Props {
  type?: 'tip' | 'caution' | 'in-depth';
  title?: string;
}

// src/components/Note.astro
const { type = 'tip', title } = Astro.props;

const config = {
  'tip': { defaultTitle: 'Tip', emoji: '💡' },
  'caution': { defaultTitle: 'Caution', emoji: '⚠️' },
  'in-depth': { defaultTitle: 'In-depth', emoji: '🔍' }
};

const currentConfig = config[type];
const emoji = currentConfig.emoji;
const category = currentConfig.defaultTitle;
---

<details class={`custom-note ${type}`}>
  <summary>{emoji} {category}{title ? `: ${title}` : ''}</summary>
  <div class="note-content">
    <slot />
  </div>
</details>