---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import ThemeIcon from './ThemeIcon.astro';
import SocialLinks from './SocialLinks.astro';
---

<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: var(--background-body, white);
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
		position: sticky;
		top: 0;
		z-index: 1000;
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 70px;
	}

	h2 { margin: 0; font-size: 1.1em; white-space: nowrap; }
	h2 a { text-decoration: none; color: inherit; }

	.internal-links {
		display: flex;
		gap: 20px;
	}

	.header-controls {
		display: flex;
		align-items: center;
		gap: 12px;
		position: relative;
		z-index: 1010;
	}

	.menu-button {
		display: none;
		background: none;
		border: 1px solid rgba(var(--gray), 30%);
		border-radius: 6px;
		cursor: pointer;
		color: inherit;
		padding: 6px;
		line-height: 0;
	}

	/* --- MOBILE OPTIMIZATION --- */
	@media (max-width: 720px) {
		.menu-button {
			display: flex !important;
		}
        
		.desktop-socials {
			display: none !important;
		}

		/* Trasformiamo i link in un menu a tendina */
		.internal-links {
			display: none; /* Nascondi di base */
			flex-direction: column;
			position: absolute;
			top: 70px;
			left: 0;
			width: 100%;
			background: var(--background-body, white);
			padding: 1.5em;
			box-shadow: 0 10px 15px rgba(0,0,0,0.1);
			gap: 1.5em;
			text-align: center;
			border-top: 1px solid rgba(var(--gray), 10%);
		}

		/* Questa classe viene aggiunta dal JavaScript al click */
		.internal-links.show {
			display: flex !important;
		}
	}
</style>