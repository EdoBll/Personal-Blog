---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import ThemeIcon from './ThemeIcon.astro';
// Se hai un componente SocialLinks, importalo qui, altrimenti usa i link semplici
---

<header>
	<nav>
		<div class="nav-left">
			<h2><a href={import.meta.env.BASE_URL}>{SITE_TITLE}</a></h2>
		</div>
		
		<div class="internal-links" id="nav-menu">
			<HeaderLink href={`${import.meta.env.BASE_URL}/`}>Home</HeaderLink>
			<HeaderLink href={`${import.meta.env.BASE_URL}/blog`}>Blog</HeaderLink>
			<HeaderLink href={`${import.meta.env.BASE_URL}/about`}>About</HeaderLink>
		</div>

		<div class="header-controls">
			<ThemeIcon />
			<button id="menu-toggle" aria-label="Menu" class="menu-button">
				<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
					<line x1="3" y1="12" x2="21" y2="12"></line>
					<line x1="3" y1="6" x2="21" y2="6"></line>
					<line x1="3" y1="18" x2="21" y2="18"></line>
				</svg>
			</button>
		</div>
	</nav>
</header>

<script>
	const initMenu = () => {
		const btn = document.getElementById('menu-toggle');
		const menu = document.getElementById('nav-menu');
		if (btn && menu) {
			btn.onclick = (e) => {
				e.stopPropagation();
				menu.classList.toggle('show');
			};
			// Chiudi se clicchi fuori
			document.onclick = () => menu.classList.remove('show');
		}
	};
	initMenu();
	document.addEventListener('astro:after-swap', initMenu);
</script>

<style>
	header {
		margin: 0;
		padding: 0 1em;
		background-color: var(--background-body);
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
		position: sticky;
		top: 0;
		z-index: 1000;
		width: 100%;
	}

	nav {
		display: flex !important; /* Forza flex invece di grid */
		align-items: center;
		justify-content: space-between;
		height: 70px;
		max-width: 960px;
		margin: 0 auto;
		flex-wrap: nowrap; /* Impedisce al contenuto di andare a capo */
	}

	h2 { margin: 0; font-size: 1.1em; white-space: nowrap; }
	h2 a { text-decoration: none; color: rgb(var(--black)); }

	.header-controls {
		display: flex;
		align-items: center;
		gap: 10px;
	}

	.menu-button {
		display: none;
		background: rgba(var(--gray), 0.1);
		border: 1px solid rgba(var(--gray), 0.2);
		border-radius: 6px;
		padding: 5px;
		cursor: pointer;
		color: rgb(var(--black));
	}

	.internal-links {
		display: flex;
		gap: 20px;
	}

	@media (max-width: 720px) {
		.menu-button { display: flex !important; }

		.internal-links {
			display: none; 
			flex-direction: column;
			position: absolute;
			top: 70px;
			left: 0;
			width: 100%;
			background-color: var(--background-body);
			padding: 1.5rem;
			box-shadow: 0 10px 15px rgba(0,0,0,0.1);
			gap: 1rem;
		}

		.internal-links.show { display: flex !important; }
	}
</style>